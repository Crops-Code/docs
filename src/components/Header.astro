---
import Search from '@astrojs/starlight/components/Search.astro';
---

<div class="header sl-flex">
  <div class="sl-flex header-start">
    <a href="/" class="site-title-link">
      <img src="/logo-small-docs.png" alt="CropsCode Docs" class="header-logo" />
    </a>
  </div>
  <div class="sl-flex header-end">
    <a href="https://github.com/Crops-Code" target="_blank" rel="noopener noreferrer" class="header-icon-link" aria-label="GitHub">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
    </a>
    <Search {...Astro.props} />
    <docs-theme-toggle>
      <button class="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </docs-theme-toggle>
    <a href="https://admin.cropscode.io/login" class="header-login">Log in</a>
    <a href="https://admin.cropscode.io/register?trial=true" class="header-signup">Sign up →</a>
  </div>
</div>

<script is:inline>
  (function() {
    var storageKey = 'starlight-theme';
    function getTheme() {
      var stored = typeof localStorage !== 'undefined' && localStorage.getItem(storageKey);
      if (stored === 'dark' || stored === 'light') return stored;
      return matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }
    function updateIcons() {
      var theme = getTheme();
      document.querySelectorAll('docs-theme-toggle').forEach(function(el) {
        var sun = el.querySelector('.icon-sun');
        var moon = el.querySelector('.icon-moon');
        if (sun) sun.style.display = theme === 'dark' ? 'block' : 'none';
        if (moon) moon.style.display = theme === 'dark' ? 'none' : 'block';
      });
    }
    updateIcons();
    document.addEventListener('click', function(e) {
      var btn = e.target.closest && e.target.closest('docs-theme-toggle .theme-toggle');
      if (!btn) return;
      var current = getTheme();
      var next = current === 'dark' ? 'light' : 'dark';
      if (typeof localStorage !== 'undefined') localStorage.setItem(storageKey, next);
      document.documentElement.dataset.theme = next;
      updateIcons();
    });
    matchMedia('(prefers-color-scheme: light)').addEventListener('change', updateIcons);

    function splitHeroTitle() {
      var h1 = document.querySelector('.hero h1');
      if (h1 && !h1.dataset.split) {
        h1.dataset.split = '1';
        var text = h1.textContent || '';
        var idx = text.indexOf('CropsCode');
        if (idx >= 0) {
          var before = text.slice(0, idx);
          var brand = text.slice(idx, idx + 9);
          h1.innerHTML = '<span class="hero-line1">' + before + '</span><span class="hero-line2">' + brand + '</span>';
        }
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', splitHeroTitle);
    } else {
      splitHeroTitle();
    }
  })();
</script>

<style>
  .header {
    height: var(--sl-nav-height, 3rem);
    padding-inline: var(--sl-nav-pad-x, 1rem);
    align-items: center;
    justify-content: space-between;
    background: var(--sl-color-bg-nav);
    border-bottom: 1px solid var(--sl-color-hairline);
    gap: 0.75rem;
  }

  .header-start {
    align-items: center;
  }

  .site-title-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .site-title-link:hover {
    text-decoration: none;
    opacity: 0.85;
  }

  .header-logo {
    height: 38px;
    width: auto;
    object-fit: contain;
  }

  .header-end {
    align-items: center;
    gap: 0.75rem;
  }

  .header-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: var(--sl-color-gray-2);
    transition: color 200ms ease, background-color 200ms ease;
  }

  .header-icon-link:hover {
    color: var(--sl-color-text);
    background-color: var(--sl-color-hairline-light);
  }

  docs-theme-toggle {
    display: flex;
    align-items: center;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border: none;
    border-radius: 0.375rem;
    background: transparent;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    transition: color 200ms ease, background-color 200ms ease;
  }

  .theme-toggle:hover {
    color: var(--sl-color-text);
    background-color: var(--sl-color-hairline-light);
  }

  .icon-sun, .icon-moon {
    display: none;
  }

  .header-login {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 200ms ease;
    white-space: nowrap;
  }

  .header-login:hover {
    color: var(--sl-color-text);
    text-decoration: none;
  }

  .header-signup {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 700;
    color: #f3f3f3;
    background: var(--docs-green, #10c0f0);
    padding: 0.5rem 1.125rem;
    border-radius: 0.375rem;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 200ms ease;
  }

  .header-signup:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media (max-width: 50rem) {
    .header-login, .header-signup {
      display: none;
    }
    .header-logo {
      height: 32px;
    }
  }

  @media (min-width: 50rem) {
    .header-logo {
      height: 38px;
    }
  }
</style>
