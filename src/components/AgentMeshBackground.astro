---
/**
 * Ambient "agent network" canvas as a fixed, page-wide layer for the docs
 * landing page only (it's only imported from index.mdx, so it unmounts on
 * navigation). Nodes drift, link up when near, and green work-pulses travel the
 * links; a fine pointer becomes a node in the graph. Ported from the portal's
 * HeroAgentMesh — the canvas drawing is framework-agnostic. Static single frame
 * under prefers-reduced-motion; paused while the tab is hidden.
 */
---

<canvas id="agent-mesh-bg" aria-hidden="true"></canvas>

<style>
  #agent-mesh-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    /* Behind all page content (but above the page's own background), so the
       splash copy and cards render crisply on top. */
    z-index: -1;
    opacity: 0.5;
  }
</style>

<script>
  const CYAN = '#10c0f0';
  const GREEN = '#3cb371';

  interface Node { x: number; y: number; vx: number; vy: number; box: boolean; r: number; }
  interface Pulse { a: { x: number; y: number }; b: Node; p: number; sp: number; }

  const canvas = document.getElementById('agent-mesh-bg') as HTMLCanvasElement | null;
  const ctx = canvas?.getContext('2d');

  if (canvas && ctx) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let W = 0, H = 0;
    let nodes: Node[] = [];
    let pulses: Pulse[] = [];
    let raf = 0, lastPulse = 0, lastPtrPulse = 0, visible = true;

    const fine = window.matchMedia('(pointer: fine)').matches;
    const ptrEnabled = fine && !reduced;
    const ptr = { x: 0, y: 0, on: false };

    const rand = (a: number, b: number) => a + Math.random() * (b - a);
    // Starlight tracks the active theme on <html data-theme="light|dark">.
    const isLight = () => document.documentElement.dataset.theme === 'light';

    const build = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.clientWidth;
      H = canvas.clientHeight;
      canvas.width = Math.max(1, Math.round(W * dpr));
      canvas.height = Math.max(1, Math.round(H * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const target = Math.round((W * H) / 30000);
      const count = Math.max(22, Math.min(60, target));
      nodes = Array.from({ length: count }, () => ({
        x: Math.random() * W, y: Math.random() * H,
        vx: rand(-0.16, 0.16), vy: rand(-0.16, 0.16),
        box: Math.random() < 0.28, r: rand(1.3, 2.4),
      }));
      pulses = [];
    };

    const D = 150;
    const draw = (t: number, step: boolean) => {
      const light = isLight();
      const lineBase = light ? 0.28 : 0.5;
      const dotAlpha = light ? 0.55 : 0.7;
      ctx.clearRect(0, 0, W, H);

      if (step) {
        for (const p of nodes) {
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0 || p.x > W) p.vx *= -1;
          if (p.y < 0 || p.y > H) p.vy *= -1;
        }
      }

      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          const d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < D) {
            const o = (1 - d / D) * lineBase;
            ctx.strokeStyle = `rgba(16,192,240,${o.toFixed(3)})`;
            ctx.lineWidth = 1;
            ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
          }
        }
      }

      if (ptr.on) {
        for (const p of nodes) {
          const d = Math.hypot(p.x - ptr.x, p.y - ptr.y);
          if (d < D) {
            const o = Math.min((1 - d / D) * lineBase * 1.7, 1);
            ctx.strokeStyle = `rgba(16,192,240,${o.toFixed(3)})`;
            ctx.lineWidth = 1.2;
            ctx.beginPath(); ctx.moveTo(ptr.x, ptr.y); ctx.lineTo(p.x, p.y); ctx.stroke();
          }
        }
      }

      if (step && !reduced) {
        if (t - lastPulse > 0.5 && pulses.length < 14) {
          lastPulse = t;
          const a = nodes[(Math.random() * nodes.length) | 0];
          let b: Node | null = null, bd = Infinity;
          for (const c of nodes) {
            if (c === a) continue;
            const dd = Math.hypot(c.x - a.x, c.y - a.y);
            if (dd < D && dd < bd) { bd = dd; b = c; }
          }
          if (b) pulses.push({ a, b, p: 0, sp: rand(0.012, 0.024) });
        }
        if (ptr.on && t - lastPtrPulse > 1.6 && pulses.length < 18) {
          lastPtrPulse = t;
          let b: Node | null = null, bd = Infinity;
          for (const c of nodes) {
            const dd = Math.hypot(c.x - ptr.x, c.y - ptr.y);
            if (dd < D && dd < bd) { bd = dd; b = c; }
          }
          if (b) pulses.push({ a: { x: ptr.x, y: ptr.y }, b, p: 0, sp: rand(0.012, 0.024) });
        }
        pulses = pulses.filter((pu) => pu.p < 1);
        for (const pu of pulses) pu.p += pu.sp;
      }

      for (const pu of pulses) {
        const x = pu.a.x + (pu.b.x - pu.a.x) * pu.p;
        const y = pu.a.y + (pu.b.y - pu.a.y) * pu.p;
        ctx.fillStyle = GREEN; ctx.shadowColor = GREEN; ctx.shadowBlur = 10;
        ctx.beginPath(); ctx.arc(x, y, 2.3, 0, Math.PI * 2); ctx.fill();
        ctx.shadowBlur = 0;
      }

      for (const p of nodes) {
        if (p.box) {
          ctx.fillStyle = CYAN; ctx.shadowColor = CYAN; ctx.shadowBlur = 8;
          ctx.fillRect(p.x - 3, p.y - 3, 6, 6); ctx.shadowBlur = 0;
        } else {
          ctx.fillStyle = `rgba(0,128,224,${dotAlpha})`;
          ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fill();
        }
      }

      if (ptr.on) {
        ctx.strokeStyle = 'rgba(16,192,240,0.5)'; ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.arc(ptr.x, ptr.y, 9, 0, Math.PI * 2); ctx.stroke();
        ctx.fillStyle = CYAN; ctx.shadowColor = CYAN; ctx.shadowBlur = 14;
        ctx.beginPath(); ctx.arc(ptr.x, ptr.y, 3.4, 0, Math.PI * 2); ctx.fill();
        ctx.shadowBlur = 0;
      }
    };

    let t0 = performance.now();
    const loop = (now: number) => { draw((now - t0) / 1000, true); raf = requestAnimationFrame(loop); };
    const start = () => {
      if (raf || reduced || !visible) return;
      t0 = performance.now(); lastPulse = 0; lastPtrPulse = 0;
      raf = requestAnimationFrame(loop);
    };
    const stop = () => { if (raf) cancelAnimationFrame(raf); raf = 0; };

    build();
    reduced ? draw(0, false) : start();

    const ro = new ResizeObserver(() => { build(); if (reduced) draw(0, false); });
    ro.observe(canvas);

    document.addEventListener('visibilitychange', () => {
      visible = !document.hidden;
      visible ? start() : stop();
    });

    if (ptrEnabled) {
      window.addEventListener('pointermove', (e) => {
        const r = canvas.getBoundingClientRect();
        ptr.x = e.clientX - r.left; ptr.y = e.clientY - r.top; ptr.on = true;
      });
      window.addEventListener('pointerleave', () => { ptr.on = false; });
    }
  }
</script>
