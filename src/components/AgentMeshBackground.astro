---
/**
 * Ambient "agent network" canvas as a fixed, page-wide layer for the docs
 * landing page only (it's only imported from index.mdx, so it unmounts on
 * navigation). Nodes drift, link up when near, and green work-pulses travel the
 * links; a fine pointer becomes a node in the graph. Ported from the portal's
 * HeroAgentMesh — the canvas drawing is framework-agnostic. Static single frame
 * under prefers-reduced-motion; paused while the tab is hidden.
 */
---

<!-- Ambient brand-colored orbs drifting behind the mesh (decorative). Mirrors
     the portal hero's three .hero-orb glows, lifted to a full-screen fixed
     layer for the docs landing. -->
<div class="agent-mesh-orbs" aria-hidden="true">
  <div class="agent-mesh-orb agent-mesh-orb-1"></div>
  <div class="agent-mesh-orb agent-mesh-orb-2"></div>
  <div class="agent-mesh-orb agent-mesh-orb-3"></div>
</div>
<canvas id="agent-mesh-bg" aria-hidden="true"></canvas>

<style>
  #agent-mesh-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    /* Behind all page content (but above the page's own background), so the
       splash copy and cards render crisply on top. */
    z-index: -1;
    /* Lifted so the mesh + lines read more strongly behind the hero (the copy
       still renders crisply on top at z-index 0). Tune to taste. */
    opacity: 0.85;
  }
  /* Light mode sits on a near-white background; lift the whole layer a touch
     more so the (darker) mesh reads. */
  :root[data-theme='light'] #agent-mesh-bg {
    opacity: 0.95;
  }

  /* ─── Ambient orbs — full-screen fixed layer one step behind the mesh
     (z-index -2). Ported 1:1 from the portal hero's .hero-orb-1/2/3. */
  .agent-mesh-orbs {
    position: fixed;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: -2;
  }
  .agent-mesh-orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(72px);
    opacity: 0.5;
    will-change: transform;
  }
  :root[data-theme='light'] .agent-mesh-orb {
    opacity: 0.28;
  }
  .agent-mesh-orb-1 {
    top: -8%;
    left: 8%;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, #10c0f0 0%, transparent 70%);
    animation: agent-mesh-orb-drift 19s ease-in-out infinite alternate;
  }
  .agent-mesh-orb-2 {
    top: 6%;
    right: 6%;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, #0080e0 0%, transparent 70%);
    animation: agent-mesh-orb-drift 23s ease-in-out infinite alternate-reverse;
  }
  .agent-mesh-orb-3 {
    bottom: -16%;
    left: 38%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #3cb371 0%, transparent 70%);
    opacity: 0.32;
    animation: agent-mesh-orb-drift 27s ease-in-out infinite alternate;
  }
  :root[data-theme='light'] .agent-mesh-orb-3 {
    opacity: 0.18;
  }

  /* Honour reduced-motion like the mesh canvas does — freeze the drift. */
  @media (prefers-reduced-motion: reduce) {
    .agent-mesh-orb {
      animation: none;
    }
  }

  @keyframes agent-mesh-orb-drift {
    from {
      transform: translate(0, 0) scale(1);
    }
    to {
      transform: translate(24px, -28px) scale(1.08);
    }
  }
</style>

<script>
  const CYAN = '#10c0f0';
  const GREEN = '#3cb371';

  interface Node { x: number; y: number; vx: number; vy: number; box: boolean; r: number; }
  interface Pulse { a: { x: number; y: number }; b: Node; p: number; sp: number; }

  const canvas = document.getElementById('agent-mesh-bg') as HTMLCanvasElement | null;
  const ctx = canvas?.getContext('2d');

  if (canvas && ctx) {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let W = 0, H = 0;
    let nodes: Node[] = [];
    let pulses: Pulse[] = [];
    let raf = 0, lastPulse = 0, lastPtrPulse = 0, visible = true;

    const fine = window.matchMedia('(pointer: fine)').matches;
    const ptrEnabled = fine && !reduced;
    const ptr = { x: 0, y: 0, on: false };

    const rand = (a: number, b: number) => a + Math.random() * (b - a);
    // Starlight tracks the active theme on <html data-theme="light|dark">.
    const isLight = () => document.documentElement.dataset.theme === 'light';

    const build = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.clientWidth;
      H = canvas.clientHeight;
      canvas.width = Math.max(1, Math.round(W * dpr));
      canvas.height = Math.max(1, Math.round(H * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const target = Math.round((W * H) / 20000);
      const count = Math.max(36, Math.min(84, target));
      nodes = Array.from({ length: count }, () => ({
        x: Math.random() * W, y: Math.random() * H,
        vx: rand(-0.16, 0.16), vy: rand(-0.16, 0.16),
        box: Math.random() < 0.28, r: rand(1.3, 2.4),
      }));
      pulses = [];
    };

    const D = 165;
    const draw = (t: number, step: boolean) => {
      const light = isLight();
      // Light mode needs a darker, more saturated blue (cyan on white is
      // invisible) and higher alpha; dark mode keeps the cyan glow.
      const lineRGB = light ? '12,110,205' : '16,192,240';
      const dotRGB = light ? '12,110,205' : '0,128,224';
      const boxColor = light ? '#0a6ecd' : CYAN;
      const lineBase = light ? 0.62 : 0.55;
      const dotAlpha = light ? 0.95 : 0.75;
      ctx.clearRect(0, 0, W, H);

      if (step) {
        for (const p of nodes) {
          p.x += p.vx; p.y += p.vy;
          if (p.x < 0 || p.x > W) p.vx *= -1;
          if (p.y < 0 || p.y > H) p.vy *= -1;
        }
      }

      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          const d = Math.hypot(a.x - b.x, a.y - b.y);
          if (d < D) {
            const o = (1 - d / D) * lineBase;
            ctx.strokeStyle = `rgba(${lineRGB},${o.toFixed(3)})`;
            ctx.lineWidth = 1;
            ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
          }
        }
      }

      if (ptr.on) {
        for (const p of nodes) {
          const d = Math.hypot(p.x - ptr.x, p.y - ptr.y);
          if (d < D) {
            const o = Math.min((1 - d / D) * lineBase * 1.7, 1);
            ctx.strokeStyle = `rgba(${lineRGB},${o.toFixed(3)})`;
            ctx.lineWidth = 1.2;
            ctx.beginPath(); ctx.moveTo(ptr.x, ptr.y); ctx.lineTo(p.x, p.y); ctx.stroke();
          }
        }
      }

      if (step && !reduced) {
        if (t - lastPulse > 0.5 && pulses.length < 14) {
          lastPulse = t;
          const a = nodes[(Math.random() * nodes.length) | 0];
          let b: Node | null = null, bd = Infinity;
          for (const c of nodes) {
            if (c === a) continue;
            const dd = Math.hypot(c.x - a.x, c.y - a.y);
            if (dd < D && dd < bd) { bd = dd; b = c; }
          }
          if (b) pulses.push({ a, b, p: 0, sp: rand(0.012, 0.024) });
        }
        if (ptr.on && t - lastPtrPulse > 1.6 && pulses.length < 18) {
          lastPtrPulse = t;
          let b: Node | null = null, bd = Infinity;
          for (const c of nodes) {
            const dd = Math.hypot(c.x - ptr.x, c.y - ptr.y);
            if (dd < D && dd < bd) { bd = dd; b = c; }
          }
          if (b) pulses.push({ a: { x: ptr.x, y: ptr.y }, b, p: 0, sp: rand(0.012, 0.024) });
        }
        pulses = pulses.filter((pu) => pu.p < 1);
        for (const pu of pulses) pu.p += pu.sp;
      }

      for (const pu of pulses) {
        const x = pu.a.x + (pu.b.x - pu.a.x) * pu.p;
        const y = pu.a.y + (pu.b.y - pu.a.y) * pu.p;
        ctx.fillStyle = GREEN; ctx.shadowColor = GREEN; ctx.shadowBlur = 10;
        ctx.beginPath(); ctx.arc(x, y, 2.3, 0, Math.PI * 2); ctx.fill();
        ctx.shadowBlur = 0;
      }

      for (const p of nodes) {
        if (p.box) {
          ctx.fillStyle = boxColor; ctx.shadowColor = boxColor; ctx.shadowBlur = 8;
          ctx.fillRect(p.x - 3, p.y - 3, 6, 6); ctx.shadowBlur = 0;
        } else {
          ctx.fillStyle = `rgba(${dotRGB},${dotAlpha})`;
          ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2); ctx.fill();
        }
      }

      // Subtle cursor dot — no outer ring, small radius, barely-there glow — so
      // it just anchors the connector lines instead of drawing the eye.
      if (ptr.on) {
        ctx.fillStyle = boxColor; ctx.shadowColor = boxColor; ctx.shadowBlur = 3;
        ctx.beginPath(); ctx.arc(ptr.x, ptr.y, 2, 0, Math.PI * 2); ctx.fill();
        ctx.shadowBlur = 0;
      }
    };

    let t0 = performance.now();
    const loop = (now: number) => { draw((now - t0) / 1000, true); raf = requestAnimationFrame(loop); };
    const start = () => {
      if (raf || reduced || !visible) return;
      t0 = performance.now(); lastPulse = 0; lastPtrPulse = 0;
      raf = requestAnimationFrame(loop);
    };
    const stop = () => { if (raf) cancelAnimationFrame(raf); raf = 0; };

    build();
    reduced ? draw(0, false) : start();

    const ro = new ResizeObserver(() => { build(); if (reduced) draw(0, false); });
    ro.observe(canvas);

    document.addEventListener('visibilitychange', () => {
      visible = !document.hidden;
      visible ? start() : stop();
    });

    if (ptrEnabled) {
      window.addEventListener('pointermove', (e) => {
        const r = canvas.getBoundingClientRect();
        ptr.x = e.clientX - r.left; ptr.y = e.clientY - r.top; ptr.on = true;
      });
      window.addEventListener('pointerleave', () => { ptr.on = false; });
    }
  }
</script>
