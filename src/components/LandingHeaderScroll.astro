---
/**
 * Landing-page-only header behavior, mirroring the portal home nav: the site
 * header is transparent over the hero at the top of the page, then fades in the
 * solid surface + bottom hairline + a drop shadow once scrolled ~24px.
 *
 * The transparent state is **pure CSS**, keyed on `:root[data-has-hero]` (set by
 * the splash hero) — it does not depend on any JS-added class, so it can't be
 * defeated by a stale/cached script bundle. The script is `is:inline` (embedded
 * in the page HTML, never a separately-cached asset) and only toggles the
 * `data-scrolled` attribute that switches on the solid state.
 *
 * Imported only from index.mdx, so the global style is scoped to the landing.
 */
---

<script is:inline>
  (function () {
    var header = document.querySelector('header.header');
    if (!header) return;
    function update() {
      var y = window.scrollY || document.documentElement.scrollTop || 0;
      if (y > 24) header.setAttribute('data-scrolled', 'true');
      else header.removeAttribute('data-scrolled');
    }
    update();
    // Capture-phase catches the scroll whether the window or an inner element scrolls.
    document.addEventListener('scroll', update, { passive: true, capture: true });
    window.addEventListener('scroll', update, { passive: true });
  })();
</script>

<style is:global>
  /* Transparent over the hero at the top. `:root[data-has-hero] header.header`
     is specificity (0,3,1), which outranks Header.astro's
     `:root[data-has-hero] .header { background: var(--sl-color-bg-nav) !important }`
     (0,3,0) that otherwise fills it. `background` shorthand (not just
     background-color) overrides the shorthand that rule sets. */
  :root[data-has-hero] header.header {
    background: transparent !important;
    border-bottom-color: transparent !important;
    box-shadow: none !important;
    transition:
      background-color 250ms ease,
      border-color 250ms ease,
      box-shadow 250ms ease !important;
  }
  /* On scroll: surface + crisp hairline + a soft drop shadow. The shadow is what
     makes the change read — the nav surface is nearly the page-background colour
     (especially dark theme), so the colour swap alone is imperceptible. */
  :root[data-has-hero] header.header[data-scrolled='true'] {
    background: var(--sl-color-bg-nav) !important;
    border-bottom-color: var(--sl-color-hairline-shade) !important;
    box-shadow: 0 6px 24px -6px rgba(0, 0, 0, 0.45) !important;
  }
  @media (prefers-reduced-motion: reduce) {
    :root[data-has-hero] header.header {
      transition: none !important;
    }
  }
</style>
