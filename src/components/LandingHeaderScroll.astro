---
/**
 * Landing-page-only header behavior, mirroring the portal home nav: transparent
 * over the hero at the top, then a solid surface + hairline + drop shadow once
 * scrolled ~24px.
 *
 * IMPORTANT: there are TWO ".header" elements — Starlight's outer
 * `<header class="header">` and, nested inside it, the custom Header.astro root
 * `<div class="header sl-flex header-home">`. The *inner* div carries the
 * visible surface + border, so the styles below target it (`.header-home`); the
 * outer header is cleared too so its background can't show through.
 *
 * The transparent state is pure CSS keyed on `:root[data-has-hero]` (set by the
 * splash hero), so it can't be defeated by a stale/cached script. The
 * `is:inline` script only toggles `data-scrolled` on the outer header for the
 * solid state. Imported only from index.mdx.
 */
---

<script is:inline>
  (function () {
    var header = document.querySelector('header.header');
    if (!header) return;
    function update() {
      var y = window.scrollY || document.documentElement.scrollTop || 0;
      if (y > 24) header.setAttribute('data-scrolled', 'true');
      else header.removeAttribute('data-scrolled');
    }
    update();
    document.addEventListener('scroll', update, { passive: true, capture: true });
    window.addEventListener('scroll', update, { passive: true });
  })();
</script>

<style is:global>
  /* Transparent at the top of the hero: clear the surface + border on BOTH the
     outer <header> and the inner home <div class="header header-home"> (either
     showing a fill or border would make it look "filled"). The selectors
     outrank Header.astro's `:root[data-has-hero] .header { background: ...
     !important }` (0,3,0). */
  :root[data-has-hero] header.header,
  :root[data-has-hero] header.header .header-home {
    background: transparent !important;
    border-bottom: none !important;
    box-shadow: none !important;
    transition:
      background-color 250ms ease,
      border-color 250ms ease,
      box-shadow 250ms ease !important;
  }
  /* On scroll: fill the inner surface, add ONE hairline + ONE drop shadow on it
     (the outer header stays transparent, so no doubled border/shadow). The
     shadow is what makes the change read — the nav surface is nearly the same
     colour as the page background. data-scrolled is toggled on the outer
     <header> by the script above. */
  :root[data-has-hero] header.header[data-scrolled='true'] .header-home {
    background: var(--sl-color-bg-nav) !important;
    border-bottom: 1px solid var(--sl-color-hairline-shade) !important;
    box-shadow: 0 6px 24px -6px rgba(0, 0, 0, 0.45) !important;
  }
  @media (prefers-reduced-motion: reduce) {
    :root[data-has-hero] header.header,
    :root[data-has-hero] header.header .header-home {
      transition: none !important;
    }
  }
</style>
