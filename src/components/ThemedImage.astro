---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Theme-aware image: renders the dark and light variants of a screenshot
 * and shows the one matching the reader's selected docs theme.
 *
 * Pure CSS — both variants are in the DOM and visibility follows Starlight's
 * `data-theme` attribute on <html>, which the theme picker keeps resolved to
 * a concrete `dark`/`light` value (including for "Auto"). No JS, no flash on
 * theme switch, and `loading="lazy"` keeps the hidden variant cheap.
 *
 * Usage (inside .mdx):
 *   import ThemedImage from '../../../components/ThemedImage.astro';
 *   import formDark from '../../../assets/screenshots/build-from-container-form-dark.png';
 *   import formLight from '../../../assets/screenshots/build-from-container-form-light.png';
 *
 *   <ThemedImage dark={formDark} light={formLight} alt="The From Container form" />
 */
interface Props {
  /** Image shown when the docs theme is dark. */
  dark: ImageMetadata;
  /** Image shown when the docs theme is light. */
  light: ImageMetadata;
  /** Required alt text — the text walkthrough stays canonical, but every
   *  image must still describe itself. */
  alt: string;
}

const { dark, light, alt } = Astro.props;
---

<figure class="themed-image">
  <Image src={dark} alt={alt} class="themed-image-dark" loading="lazy" />
  <Image src={light} alt={alt} class="themed-image-light" loading="lazy" />
</figure>

<style>
  .themed-image {
    margin: 1.5rem 0;
  }
  .themed-image :global(img) {
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-hairline);
  }
  :global([data-theme='light']) .themed-image-dark {
    display: none;
  }
  :global([data-theme='dark']) .themed-image-light {
    display: none;
  }
</style>
